// ─── Firestore Security Rules ─────────────────────────────────────────────────
// Firebase Console → Firestore Database → Rules → Paste ini → Publish

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Public READ — semua orang bisa baca ─────────────────────────────────
    // Renungan, ayat, perikop, pustaka — konten publik untuk jemaat
    match /devotional/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /perikop/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /verse_highlights/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /special_verses/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /prayer_topic/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /announcement/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /authors/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /ayat_categories/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /pustaka_books/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─── Blokir semua lainnya ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
