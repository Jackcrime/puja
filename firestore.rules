// ─── Firestore Security Rules ─────────────────────────────────────────────────
// Firebase Console → Firestore Database → Rules → Paste ini → Publish
//
// ⚠️  SEBELUM DEPLOY: pastikan akun admin sudah diberi custom claim { admin: true }
//     via Firebase Admin SDK:
//       import { getAuth } from "firebase-admin/auth";
//       await getAuth().setCustomUserClaims(uid, { admin: true });
//     Cara cek UID: Firebase Console → Authentication → Users → salin "User UID"

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: hanya admin yang boleh write ─────────────────────────────────
    // Gunakan custom claim — tidak hardcode UID, mudah diganti tanpa edit rules
    function isAdmin() {
      return request.auth != null
          && request.auth.token.admin == true;
    }

    // ─── Konten publik (semua orang bisa baca, hanya admin bisa write) ────────
    match /devotional/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /perikop/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /verse_highlights/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /special_verses/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /prayer_topic/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /announcement/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /authors/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /ayat_categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /pustaka_books/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Koleksi yang sebelumnya MISSING dari rules (kena block) ─────────────
    match /ayat_khusus/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /bible_readings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /ministries/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /mazmur_minggu/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /bahan_khotbah/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /pokok_doa_harian/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /ayat_nats/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Blokir semua lainnya ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
