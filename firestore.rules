// ─── Firestore Security Rules ─────────────────────────────────────────────────
// Firebase Console → Firestore Database → Rules → Paste ini → Publish
//
// ⚠️  SEBELUM DEPLOY: ganti ADMIN_UID di bawah dengan UID akun admin kamu.
//     Cara cek: Firebase Console → Authentication → Users → salin "User UID"

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: hanya admin yang boleh write ─────────────────────────────────
    function isAdmin() {
      return request.auth != null
          && request.auth.uid == "cslPJdeweaQk00Oyua77fg5dxeI2";
    }

    // ─── Konten publik (semua orang bisa baca, hanya admin bisa write) ────────
    match /devotional/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /perikop/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /verse_highlights/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /special_verses/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /prayer_topic/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /announcement/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /authors/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /ayat_categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /pustaka_books/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Koleksi yang sebelumnya MISSING dari rules (kena block) ─────────────
    match /ayat_khusus/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /bible_readings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /ministries/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /mazmur_minggu/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /bahan_khotbah/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /pokok_doa_harian/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /ayat_nats/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Blokir semua lainnya ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
