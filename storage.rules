// ─── Firebase Storage Security Rules ─────────────────────────────────────────
// Firebase Console → Storage → Rules → Paste ini → Publish

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── pustaka/ — PDF dokumen ───────────────────────────────────────────────
    match /pustaka/{fileName} {
      allow read:  if true;                     // Siapa pun bisa download PDF
      allow write: if request.auth != null      // Hanya admin (logged in)
                   && request.resource.size < 52428800   // Maks 50 MB
                   && request.resource.contentType == 'application/pdf';
    }

    // ─── audio/ — Audio renungan ──────────────────────────────────────────────
    match /audio/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.resource.size < 104857600  // Maks 100 MB
                   && request.resource.contentType.matches('audio/.*');
    }

    // ─── images/ — Gambar & thumbnail ────────────────────────────────────────
    match /images/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.resource.size < 5242880    // Maks 5 MB
                   && request.resource.contentType.matches('image/.*');
    }

    // ─── Blokir semua folder lain ─────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
