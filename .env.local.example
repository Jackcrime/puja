# ─── Supabase ─────────────────────────────────────────────────────────────────
# Ambil dari: https://supabase.com/dashboard/project/<your-project>/settings/api

# Anon key (aman diexpose ke browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — JANGAN pernah diexpose ke browser / commit ke git!
# Hanya dipakai di server (API routes, Server Components)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Bible API (tidak berubah) ─────────────────────────────────────────────────
BIBLE_APP_URL=https://alkitab-flax.vercel.app
BIBLE_API_KEY=your_bible_api_key
LAI_BIBLE_API_URL=https://bible-api.alkitab.or.id/bible-api/api/v1

CRON_SECRET=isi_random_string_panjang

AZURE_TTS_KEY=isi_key_kamu
AZURE_TTS_REGION=southeastasia
