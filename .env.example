# ─── .env.example ────────────────────────────────────────────────────────────
# Salin file ini ke .env.local dan isi nilainya.
# JANGAN commit .env.local ke repo!
#
# cp .env.example .env.local


# ─── Firebase Client SDK (NEXT_PUBLIC = aman di browser) ──────────────────────
# Firebase Console → Project Settings → Your Apps → Web App → Config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── Firebase Admin SDK (SERVER-ONLY, jangan pakai NEXT_PUBLIC) ───────────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Minify JSON ke satu baris, lalu paste di sini (tanpa newline sungguhan)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# ─── Admin Auth ───────────────────────────────────────────────────────────────
# Email akun Firebase Auth yang dipakai admin
# Catatan: JANGAN tampilkan nilai ini di UI publik (lihat app/admin/login/page.tsx)
NEXT_PUBLIC_ADMIN_EMAIL=admin@contoh.com

# ─── UploadThing ──────────────────────────────────────────────────────────────
# https://uploadthing.com → Dashboard → API Keys
UPLOADTHING_SECRET=
UPLOADTHING_APP_ID=

# ─── LAI Bible API (opsional — jika tidak di-set, fallback ke AYT SABDA) ─────
# https://bible-api.alkitab.or.id
LAI_BIBLE_API_KEY=
LAI_BIBLE_API_URL=https://bible-api.alkitab.or.id/bible-api/api/v1

# ─── Site URL (server-only, untuk AYT referer header) ─────────────────────────
# Gunakan SITE_URL (bukan NEXT_PUBLIC_) agar tidak ter-bundle ke client
SITE_URL=gkpb.or.id

# ─── Bible versi Inggris (opsional, default: KJV) ─────────────────────────────
# Pilihan: KJV | WEB | ASV | YLT
EN_BIBLE_VERSION=KJV
